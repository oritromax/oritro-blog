---
import Layout from '../layouts/Layout.astro';

const consultationTypes = [
  {
    title: 'Building A Team',
    description: 'Expert guidance on building high-performing engineering teams, from hiring strategies to team structure and culture development.',
    icon: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>'
  },
  {
    title: 'Software Architecture',
    description: 'Strategic planning and design of scalable software architectures, focusing on maintainability, performance, and future growth.',
    icon: '<path d="m15 12-8.5 8.5c-.83.83-2.17.83-3 0 0 0 0 0 0 0a2.12 2.12 0 0 1 0-3L12 9"/><path d="M17.64 15 22 10.64"/><path d="m20.91 11.7-1.25-1.25c-.6-.6-.93-1.4-.93-2.25v-.86L16.01 4.6a5.56 5.56 0 0 0-3.94-1.64H9l.92.82A6.18 6.18 0 0 1 12 8.4v1.56l2 2h2.47l2.26 1.91"/>'
  },
  {
    title: 'Digital Automation',
    description: 'Automate manual processes and improve efficiency through tailored automation solutions, futureproofing your engineering workflows.',
    icon: '<circle cx="6" cy="6" r="3"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="18" r="3"/><line x1="6" y1="9" x2="6" y2="15"/><line x1="9" y1="6" x2="15" y2="6"/><line x1="9" y1="18" x2="15" y2="18"/><line x1="18" y1="9" x2="18" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/>'
  },
  {
    title: 'Developing Team Management',
    description: 'Mentoring and guidance for new engineering managers, focusing on leadership skills, process improvement, and team dynamics.',
    icon: '<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>'
  }
];

const consultationProcess = [
  {
    title: 'Initial Discussion',
    description: 'A 30-minute scheduled call to understand your needs and challenges. I will generate a problem statement and action report based on this discussion, detailing how i can help',
  },
  {
    title: 'Problem Analysis',
    description: 'I will deep dive into the problem or challenge you are facing, analyzing the root causes and potential solutions. I will provide a detailed report with my findings.',
  },
  {
    title: 'Solution Planning',
    description: 'I will develop a solution plan tailored to your needs, including timelines, resources, and potential risks. This plan will be presented in a follow-up meeting.',
  },
  {
    title: 'Implementation Support',
    description: 'I will provide needed support during the implementation phase, ensuring that the solution is executed effectively and efficiently following the plan.',
  }
];
---

<Layout title="Consultation - Nidal Siddique Oritro">
  <div class="consult-shell">
    <!-- Hero -->
    <div class="consult-head">
      <span class="eyebrow eyebrow-accent">Consultation</span>
      <h1>Expert software engineering consultation</h1>
      <p>
        Leverage my 15+ years of experience to solve your technical challenges and build stronger engineering teams.
      </p>
      <a href="/contact" class="btn btn-solid">Schedule a consultation</a>
    </div>

    <!-- What I Consult About -->
    <section class="consult-section">
      <div class="section-head">
        <h2>What I consult about</h2>
      </div>
      <div class="consult-grid">
        {consultationTypes.map(type => (
          <div class="card consult-card">
            <div class="consult-card-head">
              <span class="consult-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={type.icon}></svg>
              </span>
              <h3>{type.title}</h3>
            </div>
            <p>{type.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- How I Consult -->
    <section class="consult-section">
      <div class="section-head">
        <h2>How I consult</h2>
      </div>
      <ol class="process">
        {consultationProcess.map((step, index) => (
          <li class="process-step">
            <span class="process-num mono-meta">{String(index + 1).padStart(2, '0')}</span>
            <div>
              <h3>{step.title}</h3>
              <p>{step.description}</p>
            </div>
          </li>
        ))}
      </ol>
    </section>

    <!-- CTA -->
    <section class="consult-section">
      <div class="card consult-cta">
        <h2>Ready to transform your engineering team?</h2>
        <p>
          Let's work together to solve your technical challenges and build a stronger engineering organization.
        </p>
        <a href="/contact" class="btn btn-solid">Get started</a>
      </div>
    </section>
  </div>
</Layout>

<style>
  .consult-shell {
    max-width: 860px;
    margin: 0 auto;
    padding: var(--sp-6) var(--sp-5);
  }
  .consult-head {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--sp-3);
    margin-bottom: var(--sp-7);
  }
  .consult-head h1 {
    font-size: clamp(26px, 4vw, 34px);
    max-width: 22ch;
  }
  .consult-head p {
    margin: 0;
    max-width: 52ch;
    color: var(--text-muted);
  }

  .consult-section {
    border-top: 1px solid var(--border);
    padding-top: var(--sp-6);
    margin-top: var(--sp-6);
  }
  .consult-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--sp-4);
  }
  .consult-card-head {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    margin-bottom: var(--sp-3);
  }
  .consult-card-head h3 { font-size: 16px; }
  .consult-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    flex: none;
    border-radius: var(--r-md);
    background: var(--accent-soft);
    color: var(--accent);
  }
  .consult-card p {
    margin: 0;
    font-size: 13.5px;
    line-height: 1.6;
    color: var(--text-body);
  }

  .process {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .process-step {
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: var(--sp-4);
    padding: var(--sp-5) 0;
    border-bottom: 1px solid var(--border);
  }
  .process-step:last-child { border-bottom: none; }
  .process-num { font-size: 15px; padding-top: 3px; }
  .process-step h3 { font-size: 17px; }
  .process-step p {
    margin: 7px 0 0;
    font-size: 14px;
    line-height: 1.65;
    color: var(--text-body);
    max-width: 62ch;
  }

  .consult-cta {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--sp-3);
    padding: var(--sp-6);
  }
  .consult-cta h2 { font-size: 24px; max-width: 24ch; }
  .consult-cta p {
    margin: 0;
    max-width: 48ch;
    color: var(--text-muted);
  }

  @media (max-width: 640px) {
    .consult-grid { grid-template-columns: 1fr; }
  }
</style>
