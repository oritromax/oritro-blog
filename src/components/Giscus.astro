---
export interface Props {
  repo?: string;
  repoId?: string;
  category?: string;
  categoryId?: string;
}

const {
  repo = 'oritromax/oritro-blog',
  repoId = 'R_kgDOOrBNvg',
  category = 'General',
  categoryId = 'DIC_kwDOOrBNvs4CuX_C'
} = Astro.props;
---

<div class="giscus-container">
  <h3>Comments</h3>
  <div id="giscus-slot"
    data-repo={repo}
    data-repo-id={repoId}
    data-category={category}
    data-category-id={categoryId}
  ></div>
</div>

<style>
  .giscus-container {
    margin-top: var(--sp-7);
    padding-top: var(--sp-5);
    border-top: 1px solid var(--border);
  }
  .giscus-container h3 {
    font-size: 19px;
    margin-bottom: var(--sp-4);
  }
</style>

<script>
  // load giscus with the active theme, and follow the site toggle
  const slot = document.getElementById("giscus-slot");
  if (slot) {
    const theme = () => (document.documentElement.dataset.theme === "dark" ? "dark" : "light");
    const s = document.createElement("script");
    s.src = "https://giscus.app/client.js";
    s.async = true;
    s.crossOrigin = "anonymous";
    const cfg: Record<string, string> = {
      "data-repo": slot.dataset.repo || "",
      "data-repo-id": slot.dataset.repoId || "",
      "data-category": slot.dataset.category || "",
      "data-category-id": slot.dataset.categoryId || "",
      "data-mapping": "title",
      "data-strict": "0",
      "data-reactions-enabled": "1",
      "data-emit-metadata": "0",
      "data-input-position": "top",
      "data-theme": theme(),
      "data-lang": "en",
      "data-loading": "lazy",
    };
    for (const [k, v] of Object.entries(cfg)) s.setAttribute(k, v);
    slot.appendChild(s);

    document.addEventListener("themechange", () => {
      const frame = document.querySelector<HTMLIFrameElement>("iframe.giscus-frame");
      frame?.contentWindow?.postMessage(
        { giscus: { setConfig: { theme: theme() } } },
        "https://giscus.app"
      );
    });
  }
</script>
