---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PostRow from '../../components/PostRow.astro';
import { tagSlug } from '../../lib/category';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');

  // key routes on the canonical slug (trim + NFC) so Unicode-normalization
  // variants of the same tag share one page
  const bySlug = new Map<string, { name: string; posts: typeof allPosts }>();
  for (const post of allPosts) {
    for (const raw of post.data.tags ?? []) {
      const slug = tagSlug(raw);
      const entry = bySlug.get(slug) ?? { name: raw.trim(), posts: [] };
      entry.posts.push(post);
      bySlug.set(slug, entry);
    }
  }

  return [...bySlug.entries()].map(([slug, { name, posts }]) => ({
    params: { tag: slug },
    props: {
      posts: [...new Set(posts)].sort(
        (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
      ),
      tag: name
    }
  }));
}

const { posts, tag } = Astro.props;
---

<Layout title={`Posts tagged with ${tag}`}>
  <div class="listing-shell">
    <nav class="listing-crumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span>/</span>
      <span>Tags</span>
    </nav>
    <div class="section-head">
      <h1 class="listing-title"><span class="tag">{tag}</span></h1>
      <span class="eyebrow">{posts.length} post{posts.length === 1 ? '' : 's'}</span>
    </div>
    {posts.map((post) => <PostRow post={post} />)}
  </div>
</Layout>

<style is:global>
  .listing-shell {
    max-width: var(--measure);
    margin: 0 auto;
    padding: var(--sp-6) var(--sp-5);
  }
  .listing-crumbs {
    display: flex;
    gap: 8px;
    font-size: 11px;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: var(--sp-4);
  }
  .listing-crumbs a {
    color: inherit;
    text-decoration: none;
    transition: color var(--t-fast);
  }
  .listing-crumbs a:hover { color: var(--accent); }
  .listing-title {
    font-size: 26px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .listing-title .tag { font-size: 14px; padding: 5px 10px; }
</style>
