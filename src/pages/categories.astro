---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { categoryVar } from '../lib/category';

const allPosts = await getCollection('blog');
const categories = [...new Set(allPosts.flatMap(post => post.data.categories || ['Uncategorized']))];

const categoryCounts = categories.map(category => {
  const count = allPosts.filter(post => post.data.categories?.includes(category)).length;
  return { category, count };
}).sort((a, b) => b.count - a.count);
---

<Layout title="All Categories">
  <div class="listing-shell">
    <nav class="listing-crumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span>/</span>
      <span>Categories</span>
    </nav>
    <div class="section-head">
      <h1 class="listing-title">All categories</h1>
      <span class="eyebrow">{categoryCounts.length} categories</span>
    </div>

    <ul class="all-cats">
      {categoryCounts.map(({ category, count }) => (
        <li style={`--cat: ${categoryVar(category)}`}>
          <a href={`/category/${encodeURIComponent(category)}`}>
            <span class="cat-dot" aria-hidden="true"></span>
            <span class="all-cats-name">{category}</span>
            <span class="mono-meta">{count} post{count === 1 ? '' : 's'}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</Layout>

<style is:global>
  .listing-shell {
    max-width: var(--measure);
    margin: 0 auto;
    padding: var(--sp-6) var(--sp-5);
  }
  .listing-crumbs {
    display: flex;
    gap: 8px;
    font-size: 11px;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: var(--sp-4);
  }
  .listing-crumbs a {
    color: inherit;
    text-decoration: none;
    transition: color var(--t-fast);
  }
  .listing-crumbs a:hover { color: var(--accent); }
  .listing-title { font-size: 26px; }

  .all-cats {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .all-cats li { border-bottom: 1px solid var(--border); }
  .all-cats a {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 13px 2px;
    text-decoration: none;
    color: var(--text-body);
    font-size: 14.5px;
    transition: color var(--t-fast);
  }
  .all-cats a:hover { color: var(--cat); }
  .all-cats .cat-dot {
    width: 7px;
    height: 7px;
    flex: none;
    border-radius: var(--r-full);
    background: var(--cat);
  }
  .all-cats-name { flex: 1; }
</style>
