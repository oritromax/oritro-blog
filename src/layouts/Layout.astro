---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  image?: string;
  canonicalUrl?: string;
  type?: "website" | "article";
  publishedTime?: string;
  noindex?: boolean;
  /** CSS value for the page-level category channel, e.g. "var(--c-ai)" */
  cat?: string;
}

const { title, description = "Blog and portfolio of Nidal Siddique Oritro — Software Engineer, Engineering Manager. Writing about software, homelab, and building teams and training and Using AI", image, canonicalUrl, type = "website", publishedTime, noindex = false, cat } = Astro.props;

const site = import.meta.env.SITE || "https://ioritro.com";
const url = canonicalUrl || new URL(Astro.url.pathname, site).href;
const ogImage = image?.startsWith("http") ? image : image ? new URL(image, site).href : `${site}/blog-avatar-finalized.jpg`;
const metaDescription = description.slice(0, 160);

const path = Astro.url.pathname;
const isHome = path === "/" || path.startsWith("/page/") || path.startsWith("/blog/") || path.startsWith("/category/") || path.startsWith("/tag/") || path === "/categories" || path === "/categories/";
const isPortfolio = path === "/portfolio" || path === "/portfolio/";
const isContact = path === "/contact" || path === "/contact/";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script is:inline>
      const saved = localStorage.getItem("theme");
      const sys = matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
      document.documentElement.dataset.theme = saved || sys;
    </script>
    <link rel="icon" type="image/svg+xml" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <!-- Primary meta -->
    <title>{title}</title>
    <meta name="description" content={metaDescription} />
    <meta name="author" content="Nidal Siddique Oritro" />
    <link rel="canonical" href={url} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="theme-color" content="#F5F4EF" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#14151A" media="(prefers-color-scheme: dark)" />
    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="Oritro's Blog" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={url} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="en_US" />
    {type === "article" && publishedTime && <meta property="article:published_time" content={publishedTime} />}
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:creator" content="@oritromax" />
  </head>
  <body style={cat ? `--cat: ${cat}` : undefined}>
    <header class="topbar">
      <div class="topbar-inner">
        <a href="/" class="brand" aria-label="Homepage">
          <span class="brand-mark" aria-hidden="true"></span>
          <span class="brand-name">
            <span class="brand-full">Nidal Siddique Oritro</span>
            <span class="brand-short" aria-hidden="true">Oritro</span>
          </span>
        </a>
        <nav class="topnav" aria-label="Main">
          <a href="/" class:list={["topnav-link", { active: isHome }]}>Home</a>
          <a href="/portfolio" class:list={["topnav-link", { active: isPortfolio }]}>Portfolio</a>
          <a href="/contact" class:list={["topnav-link", { active: isContact }]}>Contact</a>
          <button id="theme-toggle" class="icon-btn icon-btn-sm" aria-label="Switch to dark theme">
            <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
            <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
          </button>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-footer-inner">
        <p class="mono-meta">
          &copy; 2013 – {new Date().getFullYear()} Nidal Siddique Oritro. Built with Astro.
        </p>
        <div class="site-footer-links">
          <a href="/portfolio">Portfolio</a>
          <a href="/contact">Contact</a>
        </div>
      </div>
    </footer>

    <style>
      .topbar {
        position: sticky;
        top: 0;
        z-index: 40;
        height: var(--topbar);
        background: var(--bg);
        border-bottom: 1px solid var(--border);
      }
      .topbar-inner {
        max-width: var(--shell);
        height: 100%;
        margin: 0 auto;
        padding: 0 var(--sp-5);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--sp-4);
      }
      .brand {
        display: inline-flex;
        align-items: center;
        gap: 11px;
        text-decoration: none;
        min-width: 0;
      }
      .brand-mark {
        width: 16px;
        height: 16px;
        flex: none;
        background: var(--accent);
        border-radius: 3px;
        transform: rotate(45deg);
      }
      .brand-name {
        font-family: var(--font-display);
        font-weight: 600;
        font-size: 16px;
        letter-spacing: -.015em;
        color: var(--text);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .topnav {
        display: flex;
        align-items: center;
        gap: var(--sp-5);
      }
      .topnav-link {
        font-size: 11px;
        font-weight: 600;
        letter-spacing: .08em;
        text-transform: uppercase;
        text-decoration: none;
        color: var(--text-muted);
        transition: color var(--t-fast);
      }
      .topnav-link:hover { color: var(--text); }
      .topnav-link.active { color: var(--accent); }

      .site-footer {
        margin-top: var(--sp-8);
        background: var(--surface-alt);
        border-top: 1px solid var(--border);
      }
      .site-footer-inner {
        max-width: var(--shell);
        margin: 0 auto;
        padding: var(--sp-5);
        display: flex;
        flex-wrap: wrap;
        gap: var(--sp-3) var(--sp-5);
        align-items: center;
        justify-content: space-between;
      }
      .site-footer-links {
        display: flex;
        gap: var(--sp-4);
      }
      .site-footer-links a {
        font-size: 12px;
        text-decoration: none;
        color: var(--text-muted);
        transition: color var(--t-fast);
      }
      .site-footer-links a:hover { color: var(--accent); }

      /* theme toggle shows the icon for the theme you'd switch TO */
      #theme-toggle .icon-sun { display: none; }
      :global([data-theme="dark"]) #theme-toggle .icon-sun { display: block; }
      :global([data-theme="dark"]) #theme-toggle .icon-moon { display: none; }

      .brand-short { display: none; }

      @media (max-width: 560px) {
        .topbar-inner { padding: 0 var(--sp-4); }
        .brand-full { display: none; }
        .brand-short { display: inline; }
        .topnav { gap: var(--sp-3); }
        .topnav-link { font-size: 10px; letter-spacing: .06em; }
      }
    </style>

    <script>
      // theme toggle: persist + announce (Giscus listens for themechange)
      const toggle = document.getElementById("theme-toggle");
      const applyLabel = () => {
        const dark = document.documentElement.dataset.theme === "dark";
        toggle?.setAttribute("aria-label", dark ? "Switch to light theme" : "Switch to dark theme");
      };
      applyLabel();
      toggle?.addEventListener("click", () => {
        const next = document.documentElement.dataset.theme === "dark" ? "light" : "dark";
        document.documentElement.dataset.theme = next;
        localStorage.setItem("theme", next);
        applyLabel();
        document.dispatchEvent(new CustomEvent("themechange", { detail: { theme: next } }));
      });

      // code block copy buttons (markup injected by rehype-code)
      document.addEventListener("click", (e) => {
        const btn = (e.target as HTMLElement).closest?.(".code-copy") as HTMLButtonElement | null;
        if (!btn) return;
        const pre = btn.closest(".code")?.querySelector("pre");
        if (!pre) return;
        navigator.clipboard.writeText(pre.textContent || "").then(() => {
          btn.textContent = "Copied";
          setTimeout(() => { btn.textContent = "Copy"; }, 1600);
        });
      });
    </script>

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-D93EVG8RJ8"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-D93EVG8RJ8');
    </script>
    <script
        src="https://stats.ioritro.com/api/script.js"
        data-site-id="99b99f9d77d8"
        defer
    ></script>
  </body>
</html>
