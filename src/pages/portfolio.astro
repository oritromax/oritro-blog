---
import Layout from '../layouts/Layout.astro';

const experience = [
  {
    period: 'Jan 2025 — Now',
    role: 'Senior Engineering Manager',
    company: 'Cheq, A 365 Retail Market platform',
    description: 'Leading some of the best software minds to build highly scalable and extremely resilient software solutions serving millions of customers.',
    current: true
  },
  {
    period: 'Jan 2021 — Dec 2024',
    role: 'Lead Software Engineer',
    company: 'Montex Marketing LLC',
    description: 'Led a team of engineers to build and maintain CRM and eCommerce logistics solutions for a wide range of eCommerce verticals.',
  },
  {
    period: 'Feb 2020 — Sep 2020',
    role: 'Engineering Solution Consultant',
    company: 'ResponseCRM',
    description: "Consulted and actively participated in the development of 3D Secure Payment Gateway and PCI Compliance for ResponseCRM's 200K+ customers."
  },
  {
    period: 'Mar 2019 — Feb 2020',
    role: 'Senior Software Engineer',
    company: 'MonsterAds',
    description: 'Developed a custom CRM for affiliate marketing and lead generation with advanced reporting and analytics features.'
  },
  {
    period: 'Dec 2015 — Dec 2018',
    role: 'Head of Development Operation',
    company: 'United States Transit Funding, Inc',
    description: 'Led the team to develop a neural network based solution for fleet optimization, cost management, market analysis and route optimization.'
  },
  {
    period: 'Jan 2014 — Dec 2015',
    role: 'Senior Software Engineer',
    company: 'United States Transit Funding, Inc',
    description: 'Developed fleet data integration and reporting systems for large scale fleet management.'
  },
  {
    period: 'Feb 2013 — Jan 2014',
    role: 'Junior Software Engineer',
    company: 'United States Transit Funding, Inc',
    description: 'Helped develop a large scale fleet tracking system with fuel management and route optimization.'
  }
];

const talks = [
  {
    title: 'AI for enhanced efficiency',
    provider: 'Varendra University',
    date: '2025-06-28',
    description: 'A lecture on how to use AI to enhance efficiency in the workplace.',
    link: '/blog/2025-06-28-lecture-ai-for-enhanced-efficiency-varendra-university/'
  },
  {
    title: 'Understanding AI - Deep dive behind the curtain',
    provider: 'Cheq, A Cantaloupe Platform',
    date: '2025-11-05',
    description: 'A lecture on how to understand AI better and how it works.',
    link: '/blog/2025-11-05-understanding-ai-deep-dive-behind-the-curtain/'
  }
].sort((a, b) => b.date.localeCompare(a.date));

const openSourceProjects = [
  {
    title: 'React Portfolio',
    description: 'A modern react portfolio for those engineers who could not find time to build one.',
    tech: ['React', 'Tailwind'],
    stars: 15,
    forks: 7,
    link: 'https://github.com/oritromax/react-portfolio'
  },
  {
    title: 'Folder 2 Text',
    description: 'A CLI tool to turn your project into digestible context for LLMs',
    tech: ['NodeJS', 'Javascript', 'CLI'],
    stars: 4,
    forks: 2,
    link: 'https://github.com/oritromax/folder2text'
  },
  {
    title: 'Discord Antispam Bot',
    description: 'An extremely resource-efficient Discord bot to protect your server from spam and malicious users',
    tech: ['Go', 'Discord'],
    stars: 3,
    forks: 1,
    link: 'https://github.com/oritromax/antispam-bot'
  }
];

const industries = [
  { name: 'Transportation', blurb: 'Fleet management and logistics optimization systems' },
  { name: 'E-commerce', blurb: 'Scalable online retail and marketplace solutions' },
  { name: 'Fintech', blurb: 'Payment processing, financial management, accounting solutions' },
  { name: 'Education', blurb: 'Learning management and student tracking' },
  { name: 'Retail', blurb: 'Point of sale and inventory systems' },
  { name: 'CRM', blurb: 'Developing cutting edge CRM solutions' },
  { name: 'AI Usage', blurb: 'LLM-powered products, RAG pipelines, and MCP-driven internal tools' },
  { name: 'AI Model Training', blurb: 'Fine-tuning detection & language models for domain-specific use' },
];

const stats = [
  { value: '15+', label: 'Years in engineering' },
  { value: '7+', label: 'Years leading teams' },
  { value: '8', label: 'Industries served' },
  { value: 'Millions', label: 'Customers served' },
];

const techStack = [
  { group: 'Backend', cat: 'var(--c-codebox)', items: ['Go', 'TypeScript / JavaScript', 'PHP (Symfony, Laravel)', 'Node.js'] },
  { group: 'Frontend', cat: 'var(--c-selfhost)', items: ['React', 'Vue', 'Tailwind CSS', 'Astro'] },
  { group: 'Infrastructure & Observability', cat: 'var(--c-homelab)', items: ['Docker', 'Kubernetes', 'Podman', 'AWS', 'Grafana', 'Loki'] },
  { group: 'AI & Data', cat: 'var(--c-ai)', items: ['LLMs', 'RAG', 'MCP', 'Fine-tuning', 'ONNX'] },
];

const now = [
  { html: 'Leading engineering at <strong>Cheq, A 365 Retail Market platform</strong> — building scalable systems that serve millions of customers.' },
  { html: 'Running a <a href="/blog/2025-12-29-i-am-mentoring-engineers/">free mentorship program</a> for early-career engineers — covering judgment, context, and the work around the code.' },
  { html: 'Founded the <a href="/blog/2026-03-06-i-founded-rajshahi-professionals-network/">Rajshahi Professionals Network</a> — a community of technology professionals in Rajshahi.' },
  { html: 'Building internal AI knowledge systems with <strong>RAG and MCP</strong> — making organizational knowledge actually retrievable.' },
  { html: 'Speaking and writing on practical AI engineering — spec-driven workflows over prompt-fishing.' },
];
---

<Layout title="Portfolio - Nidal Siddique Oritro">
  <div class="pf-shell">
    <!-- Hero -->
    <section class="pf-hero">
      <div class="pf-hero-text">
        <span class="eyebrow eyebrow-accent">Portfolio</span>
        <h1>Nidal Siddique Oritro</h1>
        <p class="pf-hero-sub">Senior Engineering Manager · Scalable systems &amp; team leadership</p>
        <p>
          Software engineering leader with ~15 years building highly scalable, maintainable systems that serve millions of customers. Currently leading engineering at Cheq, A 365 Retail Market platform — taking small to medium-size teams from project inception to complete delivery. I thrive on challenges and projects that give me the opportunity to learn new things.
        </p>
        <p>
          My current focus is AI engineering — LLM-powered products, RAG pipelines, MCP-driven internal tools, and fine-tuning detection and language models for domain-specific use. I also write and speak on practical, spec-driven AI workflows.
        </p>
        <p>
          Outside the day job, I run a free mentorship program for early-career engineers and founded the Rajshahi Professionals Network.
        </p>
        <p>
          On a personal level, I love DIY projects — I have a 3D printer and I'm building out my own workshop.
        </p>
      </div>
      <div class="pf-hero-side">
        <img src="/hero.jpg" alt="Nidal Siddique Oritro" class="avatar pf-hero-avatar" />
        <div class="pf-hero-social">
          <a href="https://www.linkedin.com/in/oritromax/" class="icon-btn" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn profile">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
          </a>
          <a href="https://github.com/oritromax" class="icon-btn" target="_blank" rel="noopener noreferrer" aria-label="GitHub profile">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
          </a>
          <a href="/contact" class="icon-btn" aria-label="Contact page">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Stats strip -->
    <section class="stats" aria-label="Career statistics">
      {stats.map((stat) => (
        <div class="stat">
          <span class="stat-value">{stat.value}</span>
          <span class="stat-label">{stat.label}</span>
        </div>
      ))}
    </section>

    <!-- Now -->
    <section class="pf-section">
      <div class="section-head">
        <h2>Now</h2>
        <span class="eyebrow">What I'm focused on these days</span>
      </div>
      <ul class="now-list">
        {now.map((item) => (
          <li set:html={item.html} />
        ))}
      </ul>
    </section>

    <!-- Industries -->
    <section class="pf-section">
      <div class="section-head">
        <h2>Industry experience</h2>
        <span class="eyebrow">{industries.length} industries</span>
      </div>
      <div class="industries">
        {industries.map((ind) => (
          <div class="industry">
            <h3>{ind.name}</h3>
            <p>{ind.blurb}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Experience timeline -->
    <section class="pf-section">
      <div class="section-head">
        <h2>Experience</h2>
      </div>
      <div class="timeline">
        {experience.map((job) => (
          <div class:list={["role", { current: job.current }]}>
            <span class="role-date">{job.period}</span>
            <h3 class="role-title">
              {job.role}
              {job.current && <span class="chip">Now</span>}
            </h3>
            <p class="role-org">{job.company}</p>
            <p class="role-desc">{job.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Tech stack -->
    <section class="pf-section">
      <div class="section-head">
        <h2>Tech stack</h2>
      </div>
      <div class="stack">
        {techStack.map((group) => (
          <div class="stack-group" style={`--cat: ${group.cat}`}>
            <h3>{group.group}</h3>
            <div class="token-row">
              {group.items.map((item) => (
                <span class="tag">{item}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Talks -->
    <section class="pf-section">
      <div class="section-head">
        <h2>Talks &amp; lectures</h2>
      </div>
      {talks.map((talk) => (
        <div class="talk">
          <span class="mono-meta">{talk.date}</span>
          <div>
            <h3 class="talk-title">{talk.title}</h3>
            <p class="talk-provider">{talk.provider}</p>
            {talk.description && <p class="talk-desc">{talk.description}</p>}
          </div>
          {talk.link && (
            <a href={talk.link} class="btn" target={talk.link.startsWith('http') ? '_blank' : undefined} rel={talk.link.startsWith('http') ? 'noopener noreferrer' : undefined}>
              Details
            </a>
          )}
        </div>
      ))}
    </section>

    <!-- Open source -->
    <section class="pf-section">
      <div class="section-head">
        <h2>Open source</h2>
      </div>
      <div class="repos">
        {openSourceProjects.map((project) => (
          <a href={project.link} target="_blank" rel="noopener noreferrer" class="card card-link repo">
            <div class="repo-head">
              <h3>{project.title}</h3>
              <span class="mono-meta">★ {project.stars} · ⑂ {project.forks}</span>
            </div>
            <p>{project.description}</p>
            <div class="token-row">
              {project.tech.map((tech) => (
                <span class="chip">{tech}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </section>
  </div>
</Layout>

<style>
  .pf-shell {
    max-width: var(--shell);
    margin: 0 auto;
    padding: var(--sp-6) var(--sp-5) 0;
  }
  .pf-section {
    border-top: 1px solid var(--border);
    padding-top: var(--sp-6);
    margin-top: var(--sp-6);
  }

  /* hero */
  .pf-hero {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: var(--sp-7);
    align-items: start;
  }
  .pf-hero-text h1 {
    font-size: clamp(28px, 4vw, 38px);
    margin-top: var(--sp-2);
  }
  .pf-hero-sub {
    color: var(--text-muted);
    font-size: 15px;
    margin: 6px 0 var(--sp-5);
  }
  .pf-hero-text p { margin: 0 0 14px; max-width: 62ch; font-size: 16px; line-height: 1.7; }
  .pf-hero-side {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }
  .pf-hero-avatar {
    width: 100%;
    aspect-ratio: 4 / 5;
  }
  .pf-hero-social { display: flex; gap: var(--sp-2); }

  /* stats strip: hairlines top+bottom, hairline dividers between cells */
  .stats {
    margin-top: var(--sp-6);
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .stat {
    padding: var(--sp-5);
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .stat + .stat { border-left: 1px solid var(--border); }
  .stat-value {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 30px;
    letter-spacing: -.015em;
    color: var(--text);
  }
  .stat-label {
    font-size: 13.5px;
    color: var(--text-muted);
  }

  /* now */
  .now-list {
    list-style: none;
    margin: 0;
    padding: 0;
    max-width: 72ch;
  }
  .now-list li {
    position: relative;
    padding-left: 22px;
    margin-bottom: 12px;
    font-size: 15.5px;
    line-height: 1.7;
  }
  .now-list li::before {
    content: "";
    position: absolute;
    left: 2px;
    top: 10px;
    width: 5px;
    height: 5px;
    border-radius: var(--r-full);
    background: var(--accent);
  }
  .now-list :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2.5px;
  }
  .now-list :global(strong) { color: var(--text); font-weight: 600; }

  /* industries: gap-1px trick so the border color bleeds through as dividers */
  .industries {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    overflow: hidden;
  }
  .industry {
    background: var(--surface);
    padding: var(--sp-5);
  }
  .industry h3 { font-size: 17px; }
  .industry p {
    margin: 6px 0 0;
    font-size: 14px;
    line-height: 1.55;
    color: var(--text-muted);
  }

  /* timeline — the signature element of this page */
  .timeline {
    position: relative;
    padding-left: 132px;
    max-width: 780px;
  }
  .timeline::before {
    content: "";
    position: absolute;
    left: 108px;
    top: 8px;
    bottom: 8px;
    width: 1px;
    background: var(--border);
  }
  .role {
    position: relative;
    padding-bottom: var(--sp-6);
  }
  .role:last-child { padding-bottom: var(--sp-2); }
  .role-date {
    position: absolute;
    left: -132px;
    top: 2px;
    width: 108px;
    text-align: right;
    padding-right: var(--sp-5);
    font-family: var(--font-mono);
    font-size: 11.5px;
    color: var(--text-muted);
    font-variant-numeric: tabular-nums;
    line-height: 1.5;
  }
  .role::before {
    content: "";
    position: absolute;
    left: -29px;
    top: 7px;
    width: 9px;
    height: 9px;
    border-radius: var(--r-full);
    background: var(--bg);
    border: 2px solid var(--border-strong);
  }
  .role.current::before {
    border-color: var(--accent);
    background: var(--accent);
  }
  .role-title {
    font-size: 19px;
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }
  .role-org {
    margin: 3px 0 0;
    font-size: 14px;
    color: var(--accent);
  }
  .role-desc {
    margin: 8px 0 0;
    font-size: 15px;
    line-height: 1.65;
    color: var(--text-body);
    max-width: 58ch;
  }

  /* tech stack */
  .stack {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--sp-6);
  }
  .stack-group h3 {
    font-size: 15px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
    margin-bottom: var(--sp-3);
  }

  /* talks: hairline rows */
  .talk {
    display: grid;
    grid-template-columns: 96px 1fr auto;
    gap: var(--sp-4);
    align-items: start;
    padding: var(--sp-5) 0;
    border-bottom: 1px solid var(--border);
  }
  .talk:last-child { border-bottom: none; }
  .talk .mono-meta { padding-top: 4px; }
  .talk-title { font-size: 18px; }
  .talk-provider {
    margin: 2px 0 0;
    font-size: 13.5px;
    color: var(--text-muted);
  }
  .talk-desc {
    margin: 8px 0 0;
    font-size: 15px;
    line-height: 1.65;
    color: var(--text-body);
  }

  /* open source */
  .repos {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-4);
    margin-bottom: var(--sp-6);
  }
  .repo-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--sp-3);
  }
  .repo-head h3 { font-size: 17px; }
  .repo p {
    margin: 10px 0 14px;
    font-size: 14px;
    line-height: 1.6;
    color: var(--text-body);
  }

  @media (max-width: 899px) {
    .pf-hero { grid-template-columns: 1fr; }
    .pf-hero-side {
      flex-direction: row;
      align-items: center;
    }
    .pf-hero-avatar { width: 120px; }
    .stats { grid-template-columns: repeat(2, 1fr); }
    .stat:nth-child(3) { border-left: none; }
    .stat:nth-child(n + 3) { border-top: 1px solid var(--border); }
    .industries { grid-template-columns: repeat(2, 1fr); }
    .repos { grid-template-columns: 1fr; }
    .stack { grid-template-columns: 1fr; }
  }

  /* timeline collapses below 680px: dates inline, spine to the left edge */
  @media (max-width: 680px) {
    .timeline { padding-left: 24px; }
    .timeline::before { left: 0; }
    .role-date {
      position: static;
      display: block;
      width: auto;
      text-align: left;
      padding: 0 0 4px;
    }
    .role::before { left: -28px; }
    .talk { grid-template-columns: 1fr; gap: var(--sp-2); }
  }

  @media (max-width: 480px) {
    .industries { grid-template-columns: 1fr; }
  }
</style>
