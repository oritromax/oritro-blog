---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Giscus from '../../components/Giscus.astro';
import { categoryVar, postCatVar, primaryCategory, hasCategory, categoryHref, tagHref, postHref } from '../../lib/category';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry }
  }));
}

const { entry } = Astro.props;

const { Content, headings } = await entry.render();
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);

const formattedDate = new Date(entry.data.date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

const words = entry.body.split(/\s+/).filter(Boolean).length;
const readingTime = Math.max(1, Math.round(words / 200));

const categories = (entry.data.categories ?? []).map((c) => c.trim());
const tags = entry.data.tags ?? [];
const primary = primaryCategory(entry.data.categories);
const cat = postCatVar(entry.data.categories);

const allPosts = await getCollection('blog');
const others = allPosts
  .filter((p) => p.slug !== entry.slug)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const sameCategory = primary ? others.filter((p) => hasCategory(p.data.categories, primary)) : [];
const related = [...sameCategory, ...others.filter((p) => !sameCategory.includes(p))].slice(0, 3);

const site = import.meta.env.SITE || 'https://ioritro.com';
const canonicalUrl = `${site}${postHref(entry.slug)}/`;
const publishedTime = entry.data.date instanceof Date
  ? entry.data.date.toISOString()
  : new Date(entry.data.date).toISOString();
---

<Layout
  title={entry.data.title}
  description={entry.data.description}
  image={entry.data.featured_image}
  canonicalUrl={canonicalUrl}
  type="article"
  publishedTime={publishedTime}
  cat={cat}
>
  <div class="progress-bar" aria-hidden="true"></div>

  <header class="post-hero">
    <div class="post-hero-inner">
      <div class="post-hero-top">
        <a href="/" class="hero-back">← Back to posts</a>
        <div class="post-hero-share">
          <button class="icon-btn icon-btn-sm icon-btn-inverse" id="share-copy" aria-label="Copy link to this post">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
          </button>
          <a class="icon-btn icon-btn-sm icon-btn-inverse" href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(canonicalUrl)}`} target="_blank" rel="noopener noreferrer" aria-label="Share on LinkedIn">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
          </a>
        </div>
      </div>

      <nav class="post-hero-crumbs" aria-label="Breadcrumb">
        <a href="/">Home</a>
        {primary && <span>/</span>}
        {primary && <a href={categoryHref(primary)}>{primary}</a>}
      </nav>

      <h1 class="post-hero-title">{entry.data.title}</h1>

      <div class="post-hero-meta">
        {categories.map((category) => (
          <a href={categoryHref(category)} class="chip chip-inverse">{category}</a>
        ))}
        <span class="post-hero-dot" aria-hidden="true">·</span>
        <span>{readingTime} min read</span>
        <span class="post-hero-dot" aria-hidden="true">·</span>
        <time datetime={publishedTime}>{formattedDate}</time>
      </div>
    </div>
  </header>

  {entry.data.featured_image && (
    <div class="post-cover-wrap">
      <img src={entry.data.featured_image} alt={entry.data.title} class="post-cover" />
    </div>
  )}

  <div class="post-shell">
    <aside class="post-rail post-rail-left">
      {toc.length > 1 && (
        <nav class="toc" aria-label="Table of contents">
          <span class="eyebrow">On this page</span>
          <ul>
            {toc.map((h) => (
              <li class:list={[`toc-depth-${h.depth}`]}>
                <a href={`#${h.slug}`} data-toc={h.slug}>{h.text}</a>
              </li>
            ))}
          </ul>
        </nav>
      )}
    </aside>

    <article class="post-body">
      {entry.data.description && (
        <div class="summary">
          <span class="eyebrow">Summary</span>
          {entry.data.description}
        </div>
      )}

      <div class="prose">
        <Content />
      </div>

      <footer class="post-footer">
        {(categories.length > 0 || tags.length > 0) && (
          <div class="token-row">
            {categories.map((category) => (
              <a href={categoryHref(category)} class="chip" style={`--cat: ${categoryVar(category)}`}>{category}</a>
            ))}
            {categories.length > 0 && tags.length > 0 && <span class="token-sep"></span>}
            {tags.map((tag) => (
              <a href={tagHref(tag)} class="tag">{tag}</a>
            ))}
          </div>
        )}
        <p class="mono-meta">Published {formattedDate}</p>
        <div class="author">
          <img src="/blog-avatar-final.jpg" alt="Nidal Siddique Oritro" class="avatar author-avatar" width="56" height="56" />
          <div>
            <p class="author-name">{entry.data.author}</p>
            <p class="author-blurb">Software Engineer turned Engineering Manager. Writing about software, teams, homelab, and AI.</p>
          </div>
        </div>
      </footer>

      <Giscus />
    </article>

    <aside class="post-rail" aria-hidden="true"></aside>
  </div>

  {related.length > 0 && (
    <section class="related">
      <div class="related-inner">
        <div class="section-head bare">
          <h2>Keep reading</h2>
        </div>
        <div class="related-grid">
          {related.map((p) => (
            <a href={postHref(p.slug)} class="card card-link related-card" style={`--cat: ${postCatVar(p.data.categories)}`}>
              <span class="mono-meta">{p.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: '2-digit' })}</span>
              <h3>{p.data.title}</h3>
              {p.data.description && <p>{p.data.description}</p>}
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</Layout>

<style>
  .progress-bar {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 50;
    height: 2px;
    width: 0;
    background: var(--cat);
  }

  /* full-bleed hero band in the category color, darkened so white text
     passes 4.5:1 against all nine categories in both themes */
  .post-hero {
    background: color-mix(in srgb, var(--cat) 58%, var(--band-dark));
    color: var(--hero-ink);
    padding: var(--sp-6) 0 var(--sp-7);
  }
  .post-hero-inner {
    max-width: var(--shell);
    margin: 0 auto;
    padding: 0 var(--sp-5);
  }
  .post-hero-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-4);
    margin-bottom: var(--sp-6);
  }
  .hero-back {
    display: inline-flex;
    align-items: center;
    padding: 7px 14px;
    font-size: 12.5px;
    font-weight: 500;
    border-radius: var(--r-md);
    border: 1px solid rgba(255, 255, 255, .3);
    background: rgba(255, 255, 255, .12);
    color: var(--hero-ink);
    text-decoration: none;
    transition: background var(--t-fast);
  }
  .hero-back:hover { background: rgba(255, 255, 255, .22); }
  .post-hero-share { display: flex; gap: var(--sp-2); }

  .post-hero-crumbs {
    display: flex;
    gap: 8px;
    font-size: 11.5px;
    letter-spacing: .04em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, .75);
    margin-bottom: var(--sp-4);
  }
  .post-hero-crumbs a {
    color: inherit;
    text-decoration: none;
    transition: color var(--t-fast);
  }
  .post-hero-crumbs a:hover { color: var(--hero-ink); }

  .post-hero-title {
    color: var(--hero-ink);
    font-size: clamp(28px, 5vw, 42px);
    line-height: 1.15;
    max-width: 19ch;
    text-wrap: balance;
  }

  .post-hero-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    margin-top: var(--sp-5);
    font-size: 13px;
    color: rgba(255, 255, 255, .85);
  }
  .post-hero-dot { color: rgba(255, 255, 255, .5); }

  /* cover pulls up over the band — the ONE permitted box-shadow */
  .post-cover-wrap {
    max-width: var(--measure);
    margin: -24px auto 0;
    padding: 0 var(--sp-5);
  }
  .post-cover {
    width: 100%;
    height: auto;
    border-radius: var(--r-lg);
    border: 1px solid var(--border);
    box-shadow: 0 12px 32px -12px rgba(0, 0, 0, .22);
  }
  :global([data-theme="dark"]) .post-cover {
    box-shadow: 0 12px 32px -12px rgba(0, 0, 0, .5);
  }

  /* three-column shell: rails keep the text column optically centered */
  .post-shell {
    max-width: var(--shell);
    margin: 0 auto;
    padding: var(--sp-6) var(--sp-5) 0;
    display: grid;
    grid-template-columns: 1fr minmax(0, var(--measure)) 1fr;
    gap: var(--sp-6);
    align-items: start;
  }

  .post-rail-left {
    position: sticky;
    top: calc(var(--topbar) + var(--sp-5));
  }
  .toc ul {
    list-style: none;
    margin: var(--sp-3) 0 0;
    padding: 0;
  }
  .toc li { margin: 0; }
  .toc a {
    display: block;
    padding: 5px 0 5px 12px;
    border-left: 1px solid var(--border);
    font-size: 12.5px;
    line-height: 1.45;
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--t-fast), border-color var(--t-fast);
  }
  .toc .toc-depth-3 a { padding-left: 24px; }
  .toc a:hover { color: var(--text); }
  .toc a.active {
    color: var(--cat);
    border-left-color: var(--cat);
  }

  .post-footer {
    margin-top: var(--sp-7);
    padding-top: var(--sp-5);
    border-top: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }
  .author-avatar { width: 56px; height: 56px; flex: none; }
  .author-name {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--text);
    font-size: 15px;
  }
  .author-blurb {
    margin: 2px 0 0;
    font-size: 12.5px;
    color: var(--text-muted);
  }

  .related {
    margin-top: var(--sp-8);
    background: var(--surface-alt);
    border-top: 1px solid var(--border);
    padding: var(--sp-6) 0;
  }
  .related-inner {
    max-width: var(--shell);
    margin: 0 auto;
    padding: 0 var(--sp-5);
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-4);
  }
  .related-card h3 {
    font-size: 16px;
    line-height: 1.35;
    margin-top: 8px;
    text-wrap: balance;
  }
  .related-card p {
    margin: 8px 0 0;
    font-size: 12.5px;
    line-height: 1.55;
    color: var(--text-muted);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 899px) {
    .post-shell {
      grid-template-columns: minmax(0, var(--measure));
      justify-content: center;
    }
    .post-rail { display: none; }
    .related-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  // reading progress bar
  const bar = document.querySelector<HTMLElement>(".progress-bar");
  const onScroll = () => {
    if (!bar) return;
    const max = document.documentElement.scrollHeight - window.innerHeight;
    bar.style.width = max > 0 ? `${(window.scrollY / max) * 100}%` : "0";
  };
  onScroll();
  document.addEventListener("scroll", onScroll, { passive: true });

  // active TOC entry
  const links = new Map(
    Array.from(document.querySelectorAll<HTMLAnchorElement>("[data-toc]")).map((a) => [a.dataset.toc, a])
  );
  if (links.size > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (!e.isIntersecting) continue;
          links.forEach((a) => a.classList.remove("active"));
          links.get(e.target.id)?.classList.add("active");
        }
      },
      { rootMargin: "-88px 0px -70% 0px" }
    );
    links.forEach((_, slug) => {
      const el = slug && document.getElementById(slug);
      if (el) observer.observe(el);
    });
  }

  // copy-link share button
  document.getElementById("share-copy")?.addEventListener("click", (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    navigator.clipboard.writeText(location.href).then(() => {
      btn.setAttribute("aria-label", "Link copied");
      setTimeout(() => btn.setAttribute("aria-label", "Copy link to this post"), 1600);
    });
  });
</script>
