---
interface Props {
  currentPage: number;
  totalPages: number;
}

const { currentPage, totalPages } = Astro.props;
const pageHref = (page: number) => (page === 1 ? '/' : `/page/${page}`);
---

{totalPages > 1 && (
  <nav class="pagination" aria-label="Pagination">
    {currentPage > 1 ? (
      <a href={pageHref(currentPage - 1)} class="btn">← Previous</a>
    ) : (
      <span class="btn" aria-disabled="true">← Previous</span>
    )}

    <div class="pagination-pages">
      {Array.from({ length: totalPages }, (_, i) => i + 1).map((page) => (
        <a href={pageHref(page)} class:list={["page-num", { current: page === currentPage }]} aria-label={`Page ${page}`} aria-current={page === currentPage ? 'page' : undefined}>
          {page}
        </a>
      ))}
    </div>

    {currentPage < totalPages ? (
      <a href={pageHref(currentPage + 1)} class="btn">Next →</a>
    ) : (
      <span class="btn" aria-disabled="true">Next →</span>
    )}
  </nav>
)}

<style>
  .pagination {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-4);
    margin-top: var(--sp-6);
  }
  .pagination-pages {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--sp-2);
  }
</style>
