---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PostRow from '../../components/PostRow.astro';
import { categoryVar } from '../../lib/category';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');

  const uniqueCategories = [...new Set(allPosts.flatMap(post =>
    post.data.categories || ['Uncategorized']
  ))];

  return uniqueCategories.map(category => {
    const filteredPosts = allPosts.filter(post =>
      post.data.categories?.some(cat => cat.toLowerCase() === category.toLowerCase())
    );

    return {
      params: { category: category.toLowerCase() },
      props: {
        posts: filteredPosts.sort(
          (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
        ),
        category
      }
    };
  });
}

const { posts, category } = Astro.props;
---

<Layout title={`Category: ${category}`} cat={categoryVar(category)}>
  <div class="listing-shell">
    <nav class="listing-crumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span>/</span>
      <a href="/categories">Categories</a>
    </nav>
    <div class="section-head">
      <h1 class="listing-title">
        <span class="cat-dot" aria-hidden="true"></span>
        {category}
      </h1>
      <span class="eyebrow">{posts.length} post{posts.length === 1 ? '' : 's'}</span>
    </div>
    {posts.map((post) => <PostRow post={post} />)}
  </div>
</Layout>

<style is:global>
  .listing-shell {
    max-width: var(--measure);
    margin: 0 auto;
    padding: var(--sp-6) var(--sp-5);
  }
  .listing-crumbs {
    display: flex;
    gap: 8px;
    font-size: 11px;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: var(--sp-4);
  }
  .listing-crumbs a {
    color: inherit;
    text-decoration: none;
    transition: color var(--t-fast);
  }
  .listing-crumbs a:hover { color: var(--accent); }
  .listing-title {
    font-size: 26px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .listing-title .cat-dot {
    width: 9px;
    height: 9px;
    flex: none;
    border-radius: var(--r-full);
    background: var(--cat);
  }
</style>
