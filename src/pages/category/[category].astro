---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PostRow from '../../components/PostRow.astro';
import { categoryVar, categorySlug } from '../../lib/category';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');

  // key routes on the canonical slug so case, trailing-space, and Unicode
  // normalization variants of the same category share one page
  const bySlug = new Map<string, { name: string; posts: typeof allPosts }>();
  for (const post of allPosts) {
    for (const raw of post.data.categories ?? ['Uncategorized']) {
      const slug = categorySlug(raw);
      const entry = bySlug.get(slug) ?? { name: raw.trim(), posts: [] };
      entry.posts.push(post);
      bySlug.set(slug, entry);
    }
  }

  return [...bySlug.entries()].map(([slug, { name, posts }]) => ({
    params: { category: slug },
    props: {
      posts: [...new Set(posts)].sort(
        (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
      ),
      category: name
    }
  }));
}

const { posts, category } = Astro.props;
---

<Layout title={`Category: ${category}`} cat={categoryVar(category)}>
  <div class="listing-shell">
    <nav class="listing-crumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span>/</span>
      <a href="/categories">Categories</a>
    </nav>
    <div class="section-head">
      <h1 class="listing-title">
        <span class="cat-dot" aria-hidden="true"></span>
        {category}
      </h1>
      <span class="eyebrow">{posts.length} post{posts.length === 1 ? '' : 's'}</span>
    </div>
    {posts.map((post) => <PostRow post={post} />)}
  </div>
</Layout>

<style is:global>
  .listing-shell {
    max-width: var(--measure);
    margin: 0 auto;
    padding: var(--sp-6) var(--sp-5);
  }
  .listing-crumbs {
    display: flex;
    gap: 8px;
    font-size: 11px;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: var(--sp-4);
  }
  .listing-crumbs a {
    color: inherit;
    text-decoration: none;
    transition: color var(--t-fast);
  }
  .listing-crumbs a:hover { color: var(--accent); }
  .listing-title {
    font-size: 26px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .listing-title .cat-dot {
    width: 9px;
    height: 9px;
    flex: none;
    border-radius: var(--r-full);
    background: var(--cat);
  }
</style>
